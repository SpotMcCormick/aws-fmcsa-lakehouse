-- /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "athena_dbt", "target_name": "fmcsa_dev", "node_id": "model.aws_fmcsa_lakehouse.stg_fmcsa"} */
create table "awsdatacatalog"."fmcsa"."stg_fmcsa__ha"
    with (
      table_type='iceberg',
      is_external=false,location='s3://spot-lakehouse-dev/silver/iceberg/fmcsa/stg_fmcsa/2cc77c39-7318-4b67-a467-3b1fa3c27dcb',
      partitioning=ARRAY['add_year'],
      format='parquet',
      format-version=2,
      write.object-storage.enabled=false
    )
    as
      

with source as (

    select *
    from "awsdatacatalog"."fmcsa"."bronze_company_census_raw"

),

cleaned as (

    select
        cast(dot_number as bigint) as dot_number,
        legal_name,
        dba_name,
        status_code,

        case
            when status_code = 'A' then 'Active'
            when status_code = 'I' then 'Inactive'
            else 'Other'
        end as carrier_status,

        phy_city,
        phy_state,
        phy_zip,
        carrier_operation,
        business_org_desc,

        cast(power_units as integer) as power_units,
        cast(total_drivers as integer) as total_drivers,
        cast(mcs150_mileage as bigint) as mcs150_mileage,
        cast(mcs150_mileage_year as integer) as mcs150_mileage_year,

        mcs150_date as mcs150_date_raw,

        cast(date_parse(cast(add_date as varchar), '%Y%m%d') as date) as add_date,
        substr(cast(add_date as varchar), 1, 4) as add_year,
        substr(cast(add_date as varchar), 5, 2) as add_month,

        load_type,
        from_iso8601_timestamp(ingested_at_utc) as ingested_at_utc

    from source
    where add_date is not null
      and dot_number is not null

)

select *
from cleaned
